{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run FrilVault Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/apps/vscode-extension"
      ],
      "outFiles": ["${workspaceFolder}/apps/vscode-extension/dist/**/*.js"],
      "sourceMaps": true,
      "env": {
        "PATH": "${workspaceFolder}/target/debug:${env:PATH}"
      }
    }
  ]
}
