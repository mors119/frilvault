{
  "name": "frilvault",
  "displayName": "frilvault",
  "description": "Personal knowledge vault for code.",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FrilLab/frilvault"
  },
  "publisher": "FrilLab",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:frilvault.notes",
    "onCommand:frilvault.enable",
    "onCommand:frilvault.disable",
    "onCommand:frilvault.addNote",
    "onCommand:frilvault.createNoteHere",
    "onCommand:frilvault.editNote",
    "onCommand:frilvault.notesPanel.editNote",
    "onCommand:frilvault.notesPanel.openNote",
    "onCommand:frilvault.searchNotes",
    "onCommand:frilvault.showNotesForCurrentFile",
    "onCommand:frilvault.showStats",
    "onCommand:frilvault.showHealth",
    "onCommand:frilvault.applyRepairs",
    "onCommand:frilvault.refresh",
    "onCommand:frilvault.gutter.showActions",
    "onUri:frilvault"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "frilvault.notes",
          "name": "FrilVault Notes"
        }
      ]
    },
    "commands": [
      {
        "command": "frilvault.addNote",
        "title": "FrilVault: Add Note"
      },
      {
        "command": "frilvault.createNoteHere",
        "title": "FrilVault: Create Note Here"
      },
      {
        "command": "frilvault.editNote",
        "title": "FrilVault: Edit Note"
      },
      {
        "command": "frilvault.notesPanel.editNote",
        "title": "FrilVault: Edit Note"
      },
      {
        "command": "frilvault.searchNotes",
        "title": "FrilVault: Search Notes"
      },
      {
        "command": "frilvault.showNotesForCurrentFile",
        "title": "FrilVault: Show Notes For Current File",
        "icon": "$(note)"
      },
      {
        "command": "frilvault.showStats",
        "title": "FrilVault: Show Workspace Stats"
      },
      {
        "command": "frilvault.showHealth",
        "title": "FrilVault: Show Workspace Health"
      },
      {
        "command": "frilvault.applyRepairs",
        "title": "FrilVault: Apply Repairs"
      },
      {
        "command": "frilvault.refresh",
        "title": "FrilVault: Refresh"
      },
      {
        "command": "frilvault.enable",
        "title": "FrilVault: Turn On",
        "icon": "$(debug-start)"
      },
      {
        "command": "frilvault.disable",
        "title": "FrilVault: Turn Off",
        "icon": "$(debug-pause)"
      },
      {
        "command": "frilvault.gutter.showActions",
        "title": "FrilVault: Gutter Note Actions"
      },
      {
        "command": "frilvault.gutter.viewNote",
        "title": "FrilVault: View Gutter Note"
      },
      {
        "command": "frilvault.gutter.editNote",
        "title": "FrilVault: Edit Gutter Note"
      },
      {
        "command": "frilvault.gutter.deleteNote",
        "title": "FrilVault: Delete Gutter Note"
      },
      {
        "command": "frilvault.gutter.copyLink",
        "title": "FrilVault: Copy Gutter Note Link"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "frilvault.enable",
          "when": "view == frilvault.notes && !frilvault.enabled",
          "group": "navigation@0"
        },
        {
          "command": "frilvault.disable",
          "when": "view == frilvault.notes && frilvault.enabled",
          "group": "navigation@0"
        },
        {
          "command": "frilvault.addNote",
          "when": "view == frilvault.notes && frilvault.enabled",
          "group": "navigation"
        },
        {
          "command": "frilvault.refresh",
          "when": "view == frilvault.notes && frilvault.enabled",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "frilvault.showNotesForCurrentFile",
          "when": "resourceScheme == file && frilvault.enabled && workspaceFolderCount > 0",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "frilvault.createNoteHere",
          "when": "(editorHasSelection || editorTextFocus) && frilvault.enabled",
          "group": "navigation"
        },
        {
          "command": "frilvault.addNote",
          "when": "(editorHasSelection || editorTextFocus) && frilvault.enabled",
          "group": "navigation"
        },
        {
          "command": "frilvault.showNotesForCurrentFile",
          "when": "editorTextFocus && frilvault.enabled",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "frilvault.notesPanel.editNote",
          "when": "view == frilvault.notes && viewItem == frilvault.note && frilvault.enabled",
          "group": "inline"
        },
        {
          "command": "frilvault.notesPanel.openNote",
          "when": "view == frilvault.notes && viewItem == frilvault.note && frilvault.enabled",
          "group": "inline@1"
        }
      ],
      "commandPalette": [
        {
          "command": "frilvault.enable",
          "when": "!frilvault.enabled"
        },
        {
          "command": "frilvault.disable",
          "when": "frilvault.enabled"
        },
        {
          "command": "frilvault.createNoteHere",
          "when": "frilvault.enabled"
        },
        {
          "command": "frilvault.editNote",
          "when": "frilvault.enabled"
        },
        {
          "command": "frilvault.addNote",
          "when": "frilvault.enabled"
        },
        {
          "command": "frilvault.searchNotes",
          "when": "frilvault.enabled"
        },
        {
          "command": "frilvault.showNotesForCurrentFile",
          "when": "frilvault.enabled"
        },
        {
          "command": "frilvault.showStats",
          "when": "frilvault.enabled"
        },
        {
          "command": "frilvault.showHealth",
          "when": "frilvault.enabled"
        },
        {
          "command": "frilvault.applyRepairs",
          "when": "frilvault.enabled"
        }
      ]
    },
    "configuration": {
      "title": "FrilVault",
      "properties": {
        "frilvault.workspaceRoot": {
          "type": "string",
          "default": "",
          "description": "Override the workspace root used by FrilVault. Leave empty to use the first open workspace folder."
        },
        "frilvault.cliPath": {
          "type": "string",
          "default": "flvt",
          "description": "Path to the FrilVault CLI executable used by the Add Note command."
        },
        "frilvault.gutterMarkerStyle": {
          "type": "string",
          "enum": ["dot", "count", "bar"],
          "default": "dot",
          "description": "Visual style for interactive gutter note markers."
        },
        "frilvault.hoverPreviewLength": {
          "type": "number",
          "default": 800,
          "minimum": 100,
          "description": "Maximum number of characters shown in rich note hover previews before offering Open Note."
        },
        "frilvault.inlineNotes.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show compact inline note previews in the editor."
        },
        "frilvault.inlineNotes.showLineNotes": {
          "type": "boolean",
          "default": true,
          "description": "Show inline previews for line-anchored notes."
        },
        "frilvault.inlineNotes.showSymbolNotes": {
          "type": "boolean",
          "default": true,
          "description": "Show inline previews for resolved symbol-anchored notes."
        },
        "frilvault.inlineNotes.maxLength": {
          "type": "number",
          "default": 80,
          "minimum": 20,
          "description": "Maximum inline preview length before truncation with an ellipsis."
        },
        "frilvault.inlineEditor.autoSaveDebounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "description": "Delay in milliseconds before auto-saving inline note edits."
        },
        "frilvault.inlineLineNotes.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Deprecated. Use frilvault.inlineNotes.enabled and frilvault.inlineNotes.showLineNotes instead."
        },
        "frilvault.inlineLineNotes.maxLength": {
          "type": "number",
          "default": 120,
          "minimum": 20,
          "description": "Deprecated. Use frilvault.inlineNotes.maxLength instead."
        }
      }
    }
  },
  "scripts": {
    "build:native": "node scripts/build-native.js",
    "vscode:prepublish": "npm run package",
    "compile": "npm run build:native && npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "node scripts/build-native.js --production && npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "26.1.0",
    "typescript-eslint": "^8.62.1",
    "eslint": "^10.6.0",
    "esbuild": "^0.28.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  }
}
